{
  "name": "six-cities",
  "version": "4.0.0",
  "description": "Проект «Шесть городов» от HTML Academy",
  "keywords": [
    "rest",
    "api",
    "node.js"
  ],
  "main": "main.js",
  "scripts": {
    "start": "npm run build && node ./dist/main.rest.js",
    "start:dev": "npm run ts ./src/main.rest.ts | pino-pretty --colorize --translateTime SYS:standard",
    "build": "npm run clean && npm run compile",
    "lint": "eslint src/ --ext .ts",
    "compile": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "ts": "tsx",
    "json-server": "json-server ./mocks/mock-server-data.json --port 3000"
  },
  "devDependencies": {
    "@types/convict": "^6.1.6",
    "@types/convict-format-with-validator": "^6.0.6",
    "@types/node": "^18.19.130",
    "@typescript-eslint/eslint-plugin": "5.46.0",
    "@typescript-eslint/parser": "5.46.0",
    "convict": "^6.2.4",
    "convict-format-with-validator": "^6.2.0",
    "eslint": "8.39.0",
    "eslint-config-htmlacademy": "9.1.1",
    "eslint-config-prettier": "^10.1.8",
    "json-server": "^1.0.0-beta.6",
    "pino": "^10.3.1",
    "rimraf": "3.0.2",
    "ts-node": "10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "type": "module",
  "engines": {
    "node": "^18.0.0",
    "npm": ">=8"
  },
  "extends": [
    "plugin:prettier/recommended"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "dayjs": "^1.11.19",
    "dotenv": "17.3.1",
    "inversify": "^7.11.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2"
  }
}
